VITE_API_URL=http://localhost:8000/api
VITE_WEB_APP_URL=http://localhost:5173
# Optional override. By default the login/register/landing pages use:
# ${VITE_API_URL without /api}/api/downloads/desktop/windows
# VITE_DESKTOP_DOWNLOAD_URL=http://localhost:8000/api/downloads/desktop/windows
VITE_DESKTOP_DOWNLOAD_LABEL=Download for Windows
VITE_SALES_EMAIL=sales@carevance.example
VITE_SUPPORT_EMAIL=support@carevance.example
# Optional analytics providers. Leave blank until you have consent-aware production config.
VITE_GA_MEASUREMENT_ID=
VITE_PLAUSIBLE_DOMAIN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
# Hook point only. Google OAuth stays effectively off until backend/provider setup is approved.
VITE_GOOGLE_OAUTH_ENABLED=false
VITE_IDLE_TRACK_THRESHOLD_SECONDS=180
VITE_IDLE_AUTO_STOP_THRESHOLD_SECONDS=300
VITE_IDLE_GUARD_INTERVAL_MS=1000
