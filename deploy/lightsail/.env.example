COMPOSE_PROJECT_NAME=carevance

FRONTEND_PORT=80
BACKEND_PORT=8000

APP_NAME="CareVance"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://YOUR_LIGHTSAIL_PUBLIC_IP:8000
FRONTEND_APP_URL=http://YOUR_LIGHTSAIL_PUBLIC_IP
FRONTEND_URL=http://YOUR_LIGHTSAIL_PUBLIC_IP

APP_KEY=
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=stderr,daily
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_DATABASE=carevance
DB_USERNAME=carevance
DB_PASSWORD=change_this_database_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids
QUEUE_AFTER_COMMIT=false

CACHE_STORE=database

CORS_ALLOWED_ORIGINS=http://YOUR_LIGHTSAIL_PUBLIC_IP
CORS_ALLOWED_ORIGIN_PATTERNS=^https?:\/\/YOUR_LIGHTSAIL_PUBLIC_IP(:\d+)?$
CORS_SUPPORTS_CREDENTIALS=false
CORS_MAX_AGE=3600

API_TOKEN_TTL_MINUTES=10080
SCREENSHOT_URL_TTL_MINUTES=30
IDLE_TRACK_THRESHOLD_SECONDS=180
IDLE_AUTO_STOP_THRESHOLD_SECONDS=300

RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_LOGIN_IP_PER_MINUTE=20
RATE_LIMIT_REGISTER_PER_MINUTE=3
RATE_LIMIT_HANDOFF_PER_MINUTE=10
RATE_LIMIT_INVITATIONS_CREATE_PER_MINUTE=20
RATE_LIMIT_INVITATIONS_ACCEPT_PER_MINUTE=10
RATE_LIMIT_PASSWORD_PER_MINUTE=5
RATE_LIMIT_SCREENSHOTS_PER_MINUTE=30
RATE_LIMIT_CHAT_MESSAGES_PER_MINUTE=60
RATE_LIMIT_NOTIFICATION_PUBLISH_PER_MINUTE=10
RATE_LIMIT_DESKTOP_DOWNLOAD_PER_MINUTE=10

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="CareVance HRMS"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

DESKTOP_WINDOWS_DOWNLOAD_URL=
ATTENDANCE_LATE_AFTER=09:30:00
ATTENDANCE_SHIFT_SECONDS=28800
SAAS_TRIAL_DAYS=14
SAAS_DEFAULT_PLAN=starter
SAAS_DEFAULT_BILLING_CYCLE=monthly
INVITATION_EXPIRATION_HOURS=72
MANAGER_CAN_INVITE_EMPLOYEES=true
SALES_CONTACT_EMAIL=sales@carevance.example

PAYROLL_MODE=mock
PAYROLL_DEFAULT_CURRENCY=INR
PAYROLL_STRIPE_DISABLE_SSL_VERIFY=false
PAYROLL_STRIPE_RETURN_URL=http://YOUR_LIGHTSAIL_PUBLIC_IP/payroll
PAYROLL_STRIPE_SUCCESS_URL=http://YOUR_LIGHTSAIL_PUBLIC_IP/payroll?payment=success
PAYROLL_STRIPE_CANCEL_URL=http://YOUR_LIGHTSAIL_PUBLIC_IP/payroll?payment=cancelled
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

VITE_API_URL=http://YOUR_LIGHTSAIL_PUBLIC_IP:8000/api
VITE_WEB_APP_URL=http://YOUR_LIGHTSAIL_PUBLIC_IP
VITE_DESKTOP_DOWNLOAD_URL=http://YOUR_LIGHTSAIL_PUBLIC_IP:8000/api/downloads/desktop/windows
VITE_DESKTOP_DOWNLOAD_LABEL=Download for Windows
VITE_IDLE_TRACK_THRESHOLD_SECONDS=180
VITE_IDLE_AUTO_STOP_THRESHOLD_SECONDS=300
VITE_IDLE_GUARD_INTERVAL_MS=1000
